# packages.list
# Format: package[(cli_name)] [@platform[,platform...]] [| manager:name ...]
# Supported platforms: windows, macos, linux
# No selector = all platforms
# Multi-platform selectors use a single token with no spaces (e.g. @windows,macos)
# cli_name is optional and defaults to package name (e.g. neovim(nvim), ripgrep(rg))
# Aliases: | separates optional per-manager name overrides (e.g. fd | apt:fd-find)
# Homebrew casks use brew:cask:name (e.g. app @macos | brew:cask:app)

# -- cross-platform --
git
neovim(nvim)
ripgrep(rg)
bat
fd | apt:fd-find dnf:fd-find
fzf
jq
yq
tldr
delta | apt:git-delta dnf:git-delta pacman:git-delta brew:git-delta
zoxide
eza
lsd

# -- terminal / GUI --
starship
zsh
alacritty @macos,windows
wezterm @macos,windows
ghostty @macos | brew:cask:ghostty
tmux @macos,linux
# nushell

# editor
zed @macos,windows
neovide @windows

# -- language toolchains --
nvm
uv

# -- crypto --
openssl

